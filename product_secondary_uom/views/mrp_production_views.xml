<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mrp_production_form_view" model="ir.ui.view">
        <field name="name">mrp.production.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_compute_secondary_quantity" type="object" string="Compute Secondary UoM Qty" class="btn-primary" invisible='1'/>
            </xpath>
            <xpath expr="//field[@name='move_raw_ids']/tree/field[@name='product_uom'][2]" position="after">
                <field name="weight"/>
                <field name="height"/>
                <field name="length"/>
                <field name="width"/>
                <field name="depth"/>
                <field name="secondary_product_uom_qty"/>
                <field name="sec_uom_id"/>
                <field name="consumption_product_uom_qty"/>
                <field name="consumption_uom_id"/>
            </xpath>
        </field>
    </record>
</odoo>
