<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="purchase_order_form_inherit_seconday_uom" model="ir.ui.view">
        <field name="name">purchase.order.view.form.inherit.product.secondary.uom</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom'][2]" position="after">
                <field name="secondary_product_uom_qty"/>
                <field name="sec_uom_id"/>
                <field name="secondary_unit_price"/>
            </xpath>
        </field>
    </record>
</odoo>
