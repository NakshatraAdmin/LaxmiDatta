<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_inherit_secondary_uom" model="ir.ui.view">
        <field name="name">stock.picking.form.secondary.uom</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='product_uom']" position="after">
                <field name="secondary_product_uom_qty"/>
                <field name="sec_uom_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_move_operations_inherit" model="ir.ui.view">
        <field name="name">stock.move.form</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">
            <xpath expr="//group/group" position="after">
                <group>
                    <field name="show_generate_qr" invisible='1'/>
                </group>
            </xpath>
            <xpath expr="//field[@name='product_uom_qty']" position="after">
                <button name="action_generate_qr" type="object" string="Generate Lots/Serials" style="margin-left: -150px;" invisible="show_generate_qr == False"/>
            </xpath>

        </field>
    </record>

    <record id="view_stock_move_line_operation_tree_deliverires" model="ir.ui.view">
        <field name="name">stock.move.line.operation.tree.deliverires</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='quantity']" position="after">
                <field name="on_hand_qty" />
            </xpath>
        </field>
    </record>

</odoo>
