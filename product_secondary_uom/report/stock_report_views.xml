<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="stock.action_report_lot_label" model="ir.actions.report">
            <field name="paperformat_id" ref="garazd_product_label.paperformat_label_50x38"/>
        </record>

        <template id="stock.report_lot_label">
            <t t-call="web.basic_layout">
                <div class="oe_structure"></div>
                <div class="o_label_sheet" style="padding: 0; display: flex; justify-content: center; align-items: center; height: 100%;">
                    <table class="my-0 table table-sm table-borderless" style="width: 100%; height: 100%; margin: 0; text-align: center;">
                        <tr style="height: calc(100%/12);" t-foreach="docs" t-as="o">
                            <td style="text-align: center; vertical-align: middle; padding: 0;">
                                <div style="margin: 0 auto; display: inline-block; position: relative;" t-att-style="'width:50mm; height:28mm; border: 1px solid %s; box-sizing: border-box; overflow: hidden;' % (o.env.user.company_id.primary_color or 'black')">
                                    <t t-set="final_barcode" t-value="''"/>
                                    <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1')">
                                        <t t-if="o.product_id.valid_ean" t-set="final_barcode" t-value="'01' + '0' * (14 - len(o.product_id.barcode)) + o.product_id.barcode"/>
                                        <t name="gs1_datamatrix_lot" t-if="o.product_id.tracking == 'lot'" t-set="final_barcode" t-value="(final_barcode or '') + '10' + o.name"/>
                                        <t t-elif="o.product_id.tracking == 'serial'" t-set="final_barcode" t-value="(final_barcode or '') + '21' +     o.name"/>
                                    </t>
                                    <div style="padding: 1mm; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: space-between;">
                                        <div>
                                            <div t-if="o.product_id.default_code" class="o_label_4x12">
                                                <span class="o_label_4x12 lh-1">[<t t-out="o.product_id.default_code"/>]
                                                </span>
                                            </div>
                                            <div class="o_label_4x12">
                                                <span class="o_label_4x12 lh-1" t-field="o.product_id.name"/>
                                            </div>
                                            <div class="o_label_4x12" name="lot_name">
                                                <span class="o_label_4x12 lh-1" name="lot_name" t-field="o.name"/>
                                            </div>
                                            <div class="o_label_4x12">
                                                Qty :
                                                <span class="o_label_4x12" t-field="o.product_qty"/>
                                            </div>
                                        </div>
                                        <t t-if="env.user.has_group('stock.group_stock_lot_print_gs1')">
                                            <div t-if="final_barcode" style="align-self: flex-end;">
                                                <span t-out="final_barcode" t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'auto', 'img_style': 'overflow: hidden; width: 80%; height: 2.0rem;'}"/>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <span t-field="o.name" t-options="{'widget': 'barcode', 'img_style': 'width:100%; height:35%; display: block;'}"/>
                                        </t>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </template>

    </data>
</odoo>