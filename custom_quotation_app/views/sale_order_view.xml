<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_sale_order_form_custom" model="ir.ui.view">
            <field name="name">sale.order.form.custom</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_register_payment" string="Register Payment" type="object" class="btn-primary" invisible="state not in ('draft', 'sent')"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money" invisible="payment_count == 0">
                        <field name="payment_count" widget="statinfo" string="Payments"/>
                    </button>
                </xpath>
              <xpath expr="//page[@name='other_information']//group[@name='sales_person']/field[@name='user_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>
                <xpath expr="//page[@name='other_information']//group[@name='sales_person']/field[@name='user_id']" position="after">
                    <field name="salesperson_partner_ids" string="Salespersons" widget="many2many_tags" options="{'no_create': True, 'no_create_edit': True}"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="before">
                    <field name="product_image_1920" widget="image" options="{'width': 10, 'height': 10}" string="Product Image"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/tree/field[@name='name']" position="after">
                    <field name="bom_id"/>
                </xpath>
                <xpath expr="//field[@name='payment_term_id']" position="after">
                     <field name="bill_date"/>
                    <field name="other_references"/>
                    <field name="dispatched_through_id" context="{'show_address': 1}"/>
                    <field name="vehicle_no"/>
                </xpath>
                <xpath expr="//field[@name='sale_order_template_id']" position="after">
                    <field name="article"/>
                </xpath>
            </field>
        </record>

        <template id="report_saleorder_document_customization" inherit_id="sale.report_saleorder_document">
            <xpath expr="//table//thead//th[contains(@name, 'th_description')]" position="before">
                <th name="th_product_image" class="text-start"><span>Product Image</span></th>
            </xpath>
            <xpath expr="//table//tbody//td[contains(@name, 'td_name')]" position="before">
                <td name="td_product_image" class="text-start">
                    <img t-if="line.product_id.image_1920" t-att-src="'data:image/png;base64,' + line.product_id.image_1920.decode('utf-8')" style="max-height: 50px; max-width: 50px;"/>
                    <span t-else="True">No Image</span>
                </td>
            </xpath>
            <xpath expr="//div[@id='informations']" position="after">
                <div class="row mt-4 mb-2" id="dispatch_ref">
                    <div t-if="doc.other_references" class="col-auto col-3 mw-100 mb-2" name="other_references">
                        <strong>Other References:</strong><br/>
                        <span class="m-0" t-field="doc.other_references"/>
                    </div>
                    <div t-if="doc.dispatched_through_id" class="col-auto col-3 mw-100 mb-2" name="dispatched_through_id">
                        <strong>Dispatched Through:</strong><br/>
                        <t t-if="doc.dispatched_through_id.name">
	                        <span class="m-0" t-field="doc.dispatched_through_id.name"/>
                        </t>
                        <t t-if="doc.dispatched_through_id.street or doc.dispatched_through_id.street2">
	                        <br/>
                            <span class="m-0" t-field="doc.dispatched_through_id.street"/>
                            <span class="m-0" t-value="doc.dispatched_through_id.street2"/>
                        </t>
	                    <t t-if="doc.dispatched_through_id.city or doc.dispatched_through_id.state_id.code or doc.dispatched_through_id.zip">
		                    <br/>
		                    <span class="m-0" t-field="doc.dispatched_through_id.city"/>
	                        <span class="m-0" t-field="doc.dispatched_through_id.state_id.code"/>
	                        <span class="m-0" t-field="doc.dispatched_through_id.zip"/>
	                    </t>
	                    <t t-if="doc.dispatched_through_id.name">
		                    <br/>
		                    <span class="m-0" t-field="doc.dispatched_through_id.country_id.name"/>
	                    </t>
                    </div>
                    <div t-if="doc.vehicle_no" class="col-auto col-3 mw-100 mb-2" name="vehicle_no">
                        <strong>Vehicle No:</strong><br/>
                        <span class="m-0" t-field="doc.vehicle_no"/>
                    </div>
                    <div t-if="doc.article" class="col-auto col-3 mw-100 mb-2" name="article">
                        <strong>Artical No:</strong><br/>
                        <span class="m-0" t-field="doc.article"/>
                    </div>
                </div>
            </xpath>
        </template>
    </data>
</odoo>
