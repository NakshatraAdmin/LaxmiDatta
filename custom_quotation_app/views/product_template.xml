<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="product_template_only_form_view_inherit_seconday_uom" model="ir.ui.view">
            <field name="name">product.template.view.form.inherit.product.secondary.uom</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='categ_id']" position="before">
                    <field name="std_unit_cost" string="STD Unit Cost"/>
                    <field name="landing_cost" string="Landing Cost (%)"/>
                    <field name="net_unit_cost" string="Net Unit Cost"/>
                    <field name="consumable_unit_rate" string="Consumable Unit Rate"/>
                </xpath>
                <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="string">Unit Purchase Rate</attribute>
                </xpath>
                <xpath expr="//field[@name='default_code']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>
                <xpath expr="//field[@name='uom_po_id']" position="after">
                    <field name="is_need_secondary_uom" groups="uom.group_uom"/>
                    <field name="sec_uom_ratio" invisible="not is_need_secondary_uom" groups="uom.group_uom"/>
                    <field name="sec_uom_id" invisible="not is_need_secondary_uom" groups="uom.group_uom"/>
                    <field name="ratio" invisible="not is_need_secondary_uom" groups="uom.group_uom"/>
                    <field name="inverse_ratio" invisible="not is_need_secondary_uom" groups="uom.group_uom"/>
                </xpath>
                <xpath expr="//field[@name='inverse_ratio']" position="after">
                    <field name="is_need_consumption_uom" groups="uom.group_uom"/>
                    <field name="consumption_uom_ratio" invisible="not is_need_consumption_uom" groups="uom.group_uom"/>
                    <field name="consumption_uom_id" invisible="not is_need_consumption_uom" groups="uom.group_uom"/>
                    <field name="consumption_ratio" invisible="not is_need_consumption_uom" groups="uom.group_uom"/>
                    <field name="consumption_inverse_ratio" invisible="not is_need_consumption_uom"
                           groups="uom.group_uom"/>
                    <field name="weight"/>
                    <field name="height"/>
                    <field name="length"/>
                    <field name="width"/>
                    <field name="depth"/>
                </xpath>
                <xpath expr="//field[@name='uom_po_id']" position="after">
                    <field name="alternet_unit_qty"/>
                    <field name="alternet_ratio" string="Alternate Ratio"/>
                    <field name="inverse_alternet_ratio" string="Inverse Alternate Ratio"/>
                </xpath>
                <xpath expr="//field[@name='standard_price']/following-sibling::span" position="replace">
                    <span groups="uom.group_uom">per
                        <field name="uom_po_name" class="oe_inline"/>
                    </span>
                </xpath>
                <xpath expr="//field[@name='categ_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='detailed_type']" position="after">
                    <field name="categ_id"/>
                    <field name="item_type_id"/>
                    <field name="product_group_id" />
                    <field name="sub_product_group_id" />
                    <field name="cost_segment_id" />
                </xpath>
            </field>
        </record>

            <record id="product_normal_form_view_inherit_cqa" model="ir.ui.view">
                <field name="name">product.product.view.form.inherit.cqa</field>
                <field name="model">product.product</field>
                <field name="inherit_id" ref="product.product_normal_form_view"/>
                <field name="arch" type="xml">
                    <xpath expr="//field[@name='default_code']" position="attributes">
                        <attribute name="required">1</attribute>
                    </xpath>
                </field>
            </record>

    </data>
</odoo>