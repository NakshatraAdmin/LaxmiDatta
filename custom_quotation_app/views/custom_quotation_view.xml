        <record id="custom_quotation_easy_edit_view_bom_inherit" model="ir.ui.view">
            <field name="name">custom.quotation.product.view.form.easy.bom.inherit</field>
            <field name="model">custom.quotation</field>
            <field name="inherit_id" ref="view_custom_quotation_form"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//field[@name='unit_purchase_rate']" position="after">
                        <field name="unit_std_qty" invisible="1"/>
                        <button name="get_unit_purchase_rate"
                                string="Get Price from Product"
                                type="object"
                                class="oe_link pt-0"/>
                    </xpath>
                </data>
            </field>
