<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_account_payment_form_custom_sale_order" model="ir.ui.view">
            <field name="name">account.payment.form.custom.sale.order</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='payment_method_line_id']" position="after">
                    <field name="sale_order_id" readonly="state != 'draft'"/>
                </xpath>
            </field>
        </record>

        <record id="view_account_payment_tree_custom_sale_order" model="ir.ui.view">
            <field name="name">account.payment.list.custom.sale.order</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="sale_order_id" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
