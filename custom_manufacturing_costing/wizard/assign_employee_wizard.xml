<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assign_employee_wizard_form" model="ir.ui.view">
        <field name="name">assign.employee.wizard.form</field>
        <field name="model">assign.employee.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Employees">
                <group>
                    <field name="employee_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button string="Assign" type="object" name="action_assign_employees" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_assign_employee_to_workorder" model="ir.actions.act_window">
        <field name="name">Assign Employees</field>
        <field name="res_model">assign.employee.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_workorder_ids': active_ids}</field>
    </record>
</odoo>