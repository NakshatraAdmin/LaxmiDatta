<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_view_inherit" model="ir.ui.view">
        <field name="name">mrp.production.inherit.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="is_no_tracking"/>
            </xpath>
        </field>
    </record>

    <record id="view_mrp_production_filter_inherit" model="ir.ui.view">
        <field name="name">mrp.production.filter.inherit</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.view_mrp_production_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_to_close']" position="after">
                <field name="is_no_tracking"/>
                <filter name="filter_to_close_no_tracking"
                        string="WIP"
                        domain="[('state','=','to_close'), ('is_no_tracking','=',True)]"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_production_tree_view_inherit" model="ir.ui.view">
        <field name="name">view.mrp.tree.inherit</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_cancel']" position="after">
                <button name="button_mark_done" string="Produce All" type="object" class="oe_highlight"/>

            </xpath>

        </field>
    </record>

</odoo>
