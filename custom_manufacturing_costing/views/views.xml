<odoo>
    <data>
        <record id="view_mrp_workorder_form_inherit" model="ir.ui.view">
            <field name="name">mrp.workorder.form.inherit</field>
            <field name="model">mrp.workorder</field>
            <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="before">
                    <group string="Labour Cost Lines"
                           invisible="labour_cost not in ['fixed_price', 'based_on_repitation']">
                        <field name="line_ids">
                            <tree editable="bottom">
                                <field name="date" string="Date"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="duration"/>
                                <field name="employee_id" string="Employee"/>
                                <field name="done_qty" string="Done Qty."/>
                                <field name="total_cost" string="Total Cost"/>
                                <field name="individual_cost" string="Individual Cost" column_invisible="1"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="employee_id" string="Employee"/>
                                    <field name="individual_cost" string="Individual Cost"/>
                                </group>
                            </form>
                        </field>
                    </group>
                    <group string="Date wise summary" invisible="labour_cost not in ['fixed_price', 'based_on_repitation']">
                        <field name="datewise_summary_line_ids">
                            <tree editable="bottom">
                                <field name="date"/>
                                <field name="done_qty"/>
                                <field name="pending_qty"/>
                            </tree>
                        </field>
                    </group>
                </xpath>
                <xpath expr="//field[@name='production_id']" position="after">
                    <label for="process_cost"/>
                    <div id="" class="d-inline-flex w-100">
                        <field name="process_cost"/>
<!--                        <button name="workorder_details" type="object" string=" " icon="fa-repeat"/>-->
                    </div>
                    <field name="no_of_repitation" invisible="labour_cost != 'based_on_repitation'"/>
                    <field name="total_operation"/>
                    <field name="total_cost"/>
                </xpath>
                <xpath expr="//field[@name='production_id']" position="before">
                    <field name="labour_cost"/>
                </xpath>
            </field>
        </record>

        <record id="view_mrp_production_form_inherit" model="ir.ui.view">
            <field name="name">mrp.production.form.inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">
<!--                <xpath expr="//page[@name='miscellaneous']" position="before">-->
<!--                    <field name="related_labour_cost" invisible="1"/>-->
<!--                    <page string="Labour Cost Lines" invisible="related_labour_cost != 'fixed_price'">-->
<!--                        <field name="labour_cost_lines">-->
<!--                            <tree editable="false">-->
<!--                                <field name="employee_id" string="Employee"/>-->
<!--                                <field name="individual_cost" string="Individual Cost"/>-->
<!--                            </tree>-->
<!--                            <form>-->
<!--                                <group>-->
<!--                                    <field name="employee_id"/>-->
<!--                                    <field name="individual_cost"/>-->
<!--                                </group>-->
<!--                            </form>-->
<!--                        </field>-->
<!--                    </page>-->
<!--                </xpath>-->
                <xpath expr="//header" position="inside">
                    <button name="action_print_overview_report" type="object" string="Print Overview Report" class="oe_highlight"/>
                </xpath>
            </field>
        </record>

        <record id="action_report_overview" model="ir.actions.report">
            <field name="name">Manufacturing Overview Report</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_manufacturing_costing.report_overview_template</field>
            <field name="report_file">custom_manufacturing_costing.report_overview_template</field>
            <field name="print_report_name">'Overview Report - %s' % (object.name)</field>
        </record>


        <record id="server_action_assign_employees" model="ir.actions.server">
            <field name="name">Assign Employees</field>
            <field name="model_id" ref="mrp.model_mrp_workorder"/>
            <field name="binding_model_id" ref="mrp.model_mrp_workorder"/>
            <field name="state">code</field>
            <field name="code">
                action = {
                "type": "ir.actions.act_window",
                "res_model": "assign.employee.wizard",
                "view_mode": "form",
                "target": "new",
                "context": {
                "default_workorder_ids": env.context.get("active_ids", [])
                }
                }
            </field>
            <field name="binding_type">action</field>
        </record>


    </data>
</odoo>
