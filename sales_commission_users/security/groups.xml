<odoo>
   <odoo>
    <!-- Create a custom category -->
    <record id="sales_commission_users.sales_custom_category" model="ir.module.category">
        <field name="name">Sales Commission</field>
        <field name="parent_id" ref="base.module_category_sales_point_of_sale"/> <!-- Optional: parent category -->
    </record>

    <!-- Reference the custom category in your group -->
    <record id="group_sales_commission_access" model="res.groups">
        <field name="name">Sales Commission Access</field>
        <field name="category_id" ref="sales_commission_users.sales_custom_category"/>
    </record>
</odoo>

</odoo>


