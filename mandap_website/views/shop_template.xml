<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Product Description to Shop Page -->
    <template id="products_description_mandap" inherit_id="website_sale.products_item" name="Product Description on Shop">
        <xpath expr="//*[hasclass('o_wsale_products_item_title')]" position="after">
            <div class="oe_subdescription mb-2 text-muted small" style="max-height: 60px; overflow: hidden; text-overflow: ellipsis;">
                <div itemprop="description" t-raw="product.description_sale or product.description or ''"/>
            </div>
        </xpath>
    </template>

    <!-- Add Quick Add to Cart Button -->
    <template id="products_add_to_cart_mandap" inherit_id="website_sale.products_item" name="Quick Add to Cart on Shop">
        <xpath expr="//div[hasclass('o_wsale_product_btn')]" position="inside">
            <t t-set="product_variant_id" t-value="product._get_first_possible_variant_id()"/>
            <input name="product_id" t-att-value="product_variant_id" type="hidden"/>
            <t t-if="product_variant_id and (template_price_vals['price_reduce'] or not website.prevent_zero_price_sale)">
                <a t-if="product._website_show_quick_add()"
                   href="#" 
                   role="button" 
                   class="btn btn-primary btn-sm a-submit" 
                   aria-label="Add to Cart" 
                   title="Add to Cart">
                    <i class="fa fa-shopping-cart me-1"></i>Add to Cart
                </a>
            </t>
            <t t-else="">
                <a t-att-href="product.website_url" class="btn btn-outline-primary btn-sm" title="View Details">
                    <i class="fa fa-eye me-1"></i>View Details
                </a>
            </t>
        </xpath>
    </template>
</odoo>
