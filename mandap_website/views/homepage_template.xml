<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Professional Mandap Homepage Template -->
    <template id="mandap_homepage" name="Mandap Homepage">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'homepage'"/>
            <div id="wrap" class="oe_structure">
                
                <!-- Hero Banner Section -->
                <section class="s_banner mandap-hero-banner pt-5 pb-5" data-vcss="001" data-snippet="s_banner">
                    <div class="container">
                        <div class="row align-items-center min-vh-50">
                            <div class="col-lg-6 text-white">
                                <h1 class="display-3 fw-bold mb-4">Craft Your Dream Wedding</h1>
                                <p class="lead mb-4">Transform your special day into an unforgettable celebration with our exquisite mandap designs. From royal weddings to intimate ceremonies, we bring your vision to life.</p>
                                <div class="d-flex flex-wrap gap-3">
                                    <a href="#featured-designs" class="btn btn-primary btn-lg px-4 py-3">
                                        <i class="fa fa-image me-2"></i>View Our Designs
                                    </a>
                                    <a href="#book-now" class="btn btn-outline-light btn-lg px-4 py-3">
                                        <i class="fa fa-calendar me-2"></i>Get a Quote
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-6 mt-4 mt-lg-0">
                                <div class="mandap-hero-image">
                                    <t t-set="featured_categories" t-value="featured_categories if featured_categories else request.env['product.category'].search([('show_on_homepage', '=', True)], limit=1, order='name')"/>
                                    <t t-set="hero_category" t-value="featured_categories[0] if featured_categories and len(featured_categories) > 0 else None"/>
                                    <t t-if="hero_category and hero_category.image">
                                        <img t-attf-src="/web/image/product.category/#{hero_category.id}/image" 
                                             class="img-fluid rounded shadow-lg" 
                                             t-att-alt="hero_category.name"
                                             style="max-height: 500px; object-fit: cover; width: 100%;"/>
                                    </t>
                                    <t t-else="">
                                        <div class="bg-light rounded shadow-lg d-flex align-items-center justify-content-center" style="min-height: 400px; max-height: 500px;">
                                            <div class="text-center text-muted p-4">
                                                <i class="fa fa-image fa-5x mb-3"></i>
                                                <p class="mb-0">Upload category image to see it here</p>
                                                <p class="small mt-2">Go to: Products → Categories → Select a category → Upload Image</p>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Featured Categories Gallery -->
                <section class="mandap-featured-gallery pt-5 pb-5 bg-light" id="featured-designs">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="display-4 fw-bold mb-3">Our Featured Designs</h2>
                            <p class="lead text-muted">Discover our stunning collection of mandap designs crafted for your special moments</p>
                        </div>
                        <t t-set="featured_categories" t-value="featured_categories if featured_categories else request.env['product.category'].search([('show_on_homepage', '=', True)], limit=6, order='name')"/>
                        <t t-if="featured_categories">
                            <div class="row g-4">
                                <t t-foreach="featured_categories" t-as="category">
                                    <div class="col-lg-4 col-md-6">
                                        <div class="card mandap-design-card h-100 shadow-sm border-0">
                                            <a t-attf-href="/shop" class="text-decoration-none">
                                                <div class="mandap-card-image-wrapper position-relative overflow-hidden">
                                                    <t t-if="category.image">
                                                        <img t-attf-src="/web/image/product.category/#{category.id}/image" 
                                                             class="card-img-top mandap-card-image" 
                                                             t-att-alt="category.name"
                                                             style="height: 280px; object-fit: cover; transition: transform 0.3s ease;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 280px;">
                                                            <i class="fa fa-image fa-4x text-muted"></i>
                                                        </div>
                                                    </t>
                                                    <div class="mandap-card-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                                                        <span class="btn btn-light">View Products</span>
                                                    </div>
                                                </div>
                                            </a>
                                            <div class="card-body">
                                                <h5 class="card-title mb-2"><t t-esc="category.name"/></h5>
                                                <p class="card-text text-muted small" t-raw="category.description"/>
                                                <div class="mt-3">
                                                    <a t-attf-href="/shop" class="btn btn-primary btn-sm">
                                                        Explore <i class="fa fa-arrow-right ms-1"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="text-center py-5">
                                <p class="lead text-muted">Featured categories will appear here. Add categories and mark them to show on homepage!</p>
                            </div>
                        </t>
                    </div>
                </section>

                <!-- Services Section -->
                <section class="mandap-services pt-5 pb-5" id="services">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="display-4 fw-bold mb-3">Our Services</h2>
                            <p class="lead text-muted">Comprehensive mandap and decoration services for all your special occasions</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-lg-4 col-md-6">
                                <div class="text-center p-4 h-100">
                                    <div class="mandap-service-icon mb-4">
                                        <i class="fa fa-heart fa-4x text-primary"></i>
                                    </div>
                                    <h3 class="h4 fw-bold mb-3">Wedding Mandaps</h3>
                                    <p class="text-muted">Elegant and grand mandap designs for your wedding ceremony. Traditional and modern styles available to make your special day unforgettable.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="text-center p-4 h-100">
                                    <div class="mandap-service-icon mb-4">
                                        <i class="fa fa-star fa-4x text-warning"></i>
                                    </div>
                                    <h3 class="h4 fw-bold mb-3">Ganpati Mandaps</h3>
                                    <p class="text-muted">Beautifully decorated mandaps for Ganpati celebrations. Custom designs to honor the divine with elegance and devotion.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="text-center p-4 h-100">
                                    <div class="mandap-service-icon mb-4">
                                        <i class="fa fa-home fa-4x text-success"></i>
                                    </div>
                                    <h3 class="h4 fw-bold mb-3">Pandal Designs</h3>
                                    <p class="text-muted">Stunning pandal setups for festivals and special events. Professional installation and decoration services for memorable celebrations.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Why Choose Us Section -->
                <section class="mandap-features pt-5 pb-5 bg-light" id="why-choose-us">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="display-4 fw-bold mb-3">Why Choose Us?</h2>
                            <p class="lead text-muted">We are committed to making your celebrations extraordinary</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-lg-3 col-md-6">
                                <div class="text-center p-4">
                                    <div class="mandap-feature-icon mb-3">
                                        <i class="fa fa-check-circle fa-3x text-primary"></i>
                                    </div>
                                    <h4 class="h5 fw-bold mb-3">Premium Quality</h4>
                                    <p class="text-muted small">We use only the finest materials and craftsmanship to ensure your mandap is perfect.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="text-center p-4">
                                    <div class="mandap-feature-icon mb-3">
                                        <i class="fa fa-users fa-3x text-primary"></i>
                                    </div>
                                    <h4 class="h5 fw-bold mb-3">Experienced Team</h4>
                                    <p class="text-muted small">Our skilled designers and craftsmen bring years of experience to every project.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="text-center p-4">
                                    <div class="mandap-feature-icon mb-3">
                                        <i class="fa fa-paint-brush fa-3x text-primary"></i>
                                    </div>
                                    <h4 class="h5 fw-bold mb-3">Custom Designs</h4>
                                    <p class="text-muted small">Every design is tailored to your vision and preferences for a unique celebration.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="text-center p-4">
                                    <div class="mandap-feature-icon mb-3">
                                        <i class="fa fa-clock-o fa-3x text-primary"></i>
                                    </div>
                                    <h4 class="h5 fw-bold mb-3">On-Time Delivery</h4>
                                    <p class="text-muted small">We ensure timely setup and installation so your event runs smoothly.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="text-center p-4">
                                    <div class="mandap-feature-icon mb-3">
                                        <i class="fa fa-rupee fa-3x text-primary"></i>
                                    </div>
                                    <h4 class="h5 fw-bold mb-3">Affordable Pricing</h4>
                                    <p class="text-muted small">Competitive prices without compromising on quality or service excellence.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="text-center p-4">
                                    <div class="mandap-feature-icon mb-3">
                                        <i class="fa fa-cog fa-3x text-primary"></i>
                                    </div>
                                    <h4 class="h5 fw-bold mb-3">Complete Service</h4>
                                    <p class="text-muted small">From design consultation to installation, we handle everything for you.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Testimonials Section -->
                <section class="mandap-testimonials pt-5 pb-5" id="testimonials">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="display-4 fw-bold mb-3">What Our Customers Say</h2>
                            <p class="lead text-muted">Don't just take our word for it - hear from our satisfied customers</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-lg-4 col-md-6">
                                <div class="card mandap-testimonial-card h-100 shadow-sm border-0">
                                    <div class="card-body p-4">
                                        <div class="mb-3">
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                        </div>
                                        <p class="card-text fst-italic mb-4">"The mandap design was absolutely stunning! They made our wedding day perfect. The team was professional, creative, and delivered exactly what we wanted. Highly recommended!"</p>
                                        <div class="d-flex align-items-center">
                                            <div class="mandap-testimonial-avatar me-3">
                                                <i class="fa fa-user-circle fa-3x text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">Priya &amp; Raj</h6>
                                                <small class="text-muted">Mumbai Wedding</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="card mandap-testimonial-card h-100 shadow-sm border-0">
                                    <div class="card-body p-4">
                                        <div class="mb-3">
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                        </div>
                                        <p class="card-text fst-italic mb-4">"Professional service and beautiful designs. Our Ganpati celebration was a huge success thanks to their amazing work. The attention to detail was exceptional!"</p>
                                        <div class="d-flex align-items-center">
                                            <div class="mandap-testimonial-avatar me-3">
                                                <i class="fa fa-user-circle fa-3x text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">Sharma Family</h6>
                                                <small class="text-muted">Pune Ganpati Celebration</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="card mandap-testimonial-card h-100 shadow-sm border-0">
                                    <div class="card-body p-4">
                                        <div class="mb-3">
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                            <i class="fa fa-star text-warning"></i>
                                        </div>
                                        <p class="card-text fst-italic mb-4">"Exceeded our expectations! The team was creative, punctual, and delivered exactly what we wanted. Our wedding was truly special and memorable thanks to their beautiful mandap design."</p>
                                        <div class="d-flex align-items-center">
                                            <div class="mandap-testimonial-avatar me-3">
                                                <i class="fa fa-user-circle fa-3x text-primary"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">Mehta Family</h6>
                                                <small class="text-muted">Delhi Wedding</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Final Call to Action Section -->
                <section class="mandap-cta pt-5 pb-5 bg-primary text-white" id="book-now">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-8 text-center text-lg-start mb-4 mb-lg-0">
                                <h2 class="display-5 fw-bold mb-3">Ready to Book Your Mandap?</h2>
                                <p class="lead mb-0">Get a free quote for your special event. Our team will contact you within 24 hours to discuss your requirements.</p>
                            </div>
                            <div class="col-lg-4 text-center">
                                <a href="#contact" class="btn btn-light btn-lg px-5 py-3">
                                    <i class="fa fa-calendar-check-o me-2"></i>Contact Us
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>
</odoo>
