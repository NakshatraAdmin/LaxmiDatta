<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Custom Homepage Page Record -->
        <!-- The homepage is handled by the controller route, but we create this page record -->
        <!-- as a fallback and for SEO purposes -->
        <record id="mandap_homepage_page" model="website.page">
            <field name="name">Mandap Homepage</field>
            <field name="url">/</field>
            <field name="view_id" ref="mandap_website.mandap_homepage"/>
            <field name="is_published">True</field>
            <field name="website_indexed">True</field>
            <field name="website_meta_description">Professional mandap designs for weddings, Ganpati, and special events. Book your dream mandap today!</field>
        </record>
    </data>
</odoo>
